{
    "name": "cap_monster/client",
    "description": "PHP client for the CapMonster Cloud captcha-solving API (reCAPTCHA v2/v3, hCaptcha, FunCaptcha, GeeTest, Turnstile, image-to-text and more)",
    "keywords": ["capmonster", "captcha", "recaptcha", "hcaptcha", "funcaptcha", "geetest", "turnstile", "captcha-solver"],
    "homepage": "https://github.com/akomyagin/CapMonster",
    "minimum-stability": "stable",
    "license": "MIT",
    "type": "library",
    "authors": [
        {
            "name": "A.Komiagin",
            "email": "alkom68@gmail.com"
        }
    ],
    "support": {
        "issues": "https://github.com/akomyagin/CapMonster/issues",
        "source": "https://github.com/akomyagin/CapMonster"
    },
    "require": {
        "php": "^8.2",
        "psr/http-client": "^1.0",
        "nyholm/psr7": "^1.8",
        "jms/serializer": "^3.23"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0",
        "phpstan/phpstan": "^1.11",
        "webclient/fake-http-client": "^3.0",
        "symfony/deprecation-contracts": "^3.6"
    },
    "autoload": {
        "psr-4": {
            "CapMonsterClient\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "@php vendor/bin/phpunit",
        "test:unit": "@php vendor/bin/phpunit --testsuite Unit",
        "test:integration": "@php vendor/bin/phpunit --testsuite Integration",
        "test:functional": "@php vendor/bin/phpunit --testsuite Functional",
        "phpstan": "@php vendor/bin/phpstan analyse"
    }
}
